# Server runtime
PORT=3001
NODE_ENV=development

# Exact client origin (no trailing slash) — used for CORS and CSP connect-src
CLIENT_URL=http://localhost:5173

# Supabase — SERVER ONLY, never commit real values
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Anthropic — SERVER ONLY. Powers POST /api/transactions/parse (natural-language
# QuickAdd) and POST /api/ask (Ask Trim chat). If unset, /parse returns 503 and
# the client falls back to the structured form; /ask returns 503.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ask Trim — optional. Switches the system prompt to the cold-open variant
# (no one-shot example) for the tone audit in scripts/askEval.js. Defaults to
# one-shot when unset.
# ASK_PROMPT_VARIANT=cold-open
