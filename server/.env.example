# Server runtime
PORT=3001
NODE_ENV=development

# Exact client origin (no trailing slash) — used for CORS and CSP connect-src
CLIENT_URL=http://localhost:5173

# Supabase — SERVER ONLY, never commit real values
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Anthropic — SERVER ONLY. Powers POST /api/transactions/parse (natural-language
# transaction parser in QuickAdd). If unset, the parse endpoint returns 503 and
# the client falls back to the structured form.
ANTHROPIC_API_KEY=sk-ant-your-key-here
