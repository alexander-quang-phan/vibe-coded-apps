# Express API base URL (empty string = same-origin; in dev Vite proxies /api)
VITE_API_URL=

# Supabase public values (safe to expose to the browser).
# Only used for the Supabase Auth client SDK (login/signup -> JWT).
# The client NEVER uses these to read/write application data — that goes through our Express API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
